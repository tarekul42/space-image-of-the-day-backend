{
  "name": "space-image-of-the-day-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.3.2",
    "google-translate-api-x": "^10.7.2",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  }
}
